{
  "name": "@jurnapod/shared",
  "version": "0.3.0",
  "private": true,
  "type": "module",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    },
    "./test/fixtures": {
      "types": "./dist/test/fixtures/index.d.ts",
      "default": "./dist/test/fixtures/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src --config eslint.config.mjs",
    "test": "vitest run",
    "test:unit": "vitest run __test__/unit",
    "test:integration": "vitest run __test__/integration",
    "test:single": "vitest run"
  },
  "dependencies": {
    "@js-temporal/polyfill": "^0.5.1",
    "bcryptjs": "^3.0.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "tsc-esm-fix": "^3.1.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.0"
  }
}
