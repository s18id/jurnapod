{
  "name": "@jurnapod/db",
  "version": "0.3.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./kysely": {
      "import": "./dist/kysely/index.js",
      "types": "./dist/kysely/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "eslint src --config eslint.config.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run __test__/unit",
    "test:integration": "vitest run __test__/integration",
    "test:single": "vitest run",
    "test:watch": "vitest",
    "db:migrate": "node ./scripts/migrate.mjs",
    "db:seed": "node ./scripts/seed.mjs",
    "db:script": "node ./scripts/run-sql-script.mjs",
    "db:seed:test-items": "node ./scripts/seed-random-items.mjs",
    "db:seed:test-accounts": "node ./scripts/seed-random-accounts.mjs",
    "db:seed:test-data": "node ./scripts/seed-test-data.mjs",
    "db:seed:test-data:simple": "node ./scripts/test-seed-simple.mjs",
    "db:verify:test-data": "node ./scripts/verify-test-data.mjs",
    "db:verify:user-roles": "node ./scripts/verify-user-roles.mjs",
    "db:fix:user-outlets": "node ./scripts/fix-user-outlets.mjs",
    "db:seed:settings": "node ./scripts/seed-settings-from-env.mjs",
    "db:smoke": "node ./scripts/smoke.mjs",
    "db:backfill:pos-journals": "node ./scripts/backfill-pos-journals.mjs",
    "db:backfill:reservation-ts": "node ./scripts/backfill-reservation-start-end-ts.mjs",
    "db:reconcile:pos-journals": "node ./scripts/reconcile-pos-journals.mjs",
    "db:audit:system-roles": "node ./scripts/audit-system-roles.mjs",
    "db:consolidate:system-roles": "node ./scripts/consolidate-system-role-duplicates.mjs"
  },
  "dependencies": {
    "@node-rs/argon2": "^2.0.2",
    "bcryptjs": "^3.0.2",
    "dotenv": "^16.4.7",
    "kysely": "^0.28.2",
    "mysql2": "^3.15.3"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "kysely-codegen": "^0.12.0",
    "tsx": "^4.19.0",
    "vitest": "^3.0.0"
  }
}
