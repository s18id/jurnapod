{
  "name": "@jurnapod/telemetry",
  "version": "0.3.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./slo": {
      "types": "./dist/slo.d.ts",
      "default": "./dist/slo.js"
    },
    "./metrics": {
      "types": "./dist/metrics.d.ts",
      "default": "./dist/metrics.js"
    },
    "./alert-config": {
      "types": "./dist/alert-config.d.ts",
      "default": "./dist/alert-config.js"
    },
    "./correlation": {
      "types": "./dist/correlation.d.ts",
      "default": "./dist/correlation.js"
    },
    "./labels": {
      "types": "./dist/labels.d.ts",
      "default": "./dist/labels.js"
    },
    "./runtime": {
      "types": "./dist/runtime/index.d.ts",
      "default": "./dist/runtime/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src --config eslint.config.mjs",
    "test": "vitest run",
    "test:unit": "vitest run __test__/unit",
    "test:integration": "vitest run __test__/integration",
    "test:single": "vitest run"
  },
  "dependencies": {
    "prom-client": "^15.1.3",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "25.3.0",
    "tsx": "^4.20.3",
    "typescript": "^5.7.3",
    "vitest": "^3.0.0"
  }
}
