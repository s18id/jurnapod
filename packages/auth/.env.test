# Test-only secrets - safe to commit (NOT production values)
# These are used for unit testing the auth package

# Token Secrets (minimum 32 characters)
AUTH_TEST_ACCESS_TOKEN_SECRET=test-secret-32-chars-long-for-testing!!
AUTH_TEST_REFRESH_TOKEN_SECRET=refresh-secret-32-chars-long-for-test!!
AUTH_TEST_ACCESS_TOKEN_TTL_SECONDS=900
AUTH_TEST_REFRESH_TOKEN_TTL_SECONDS=604800
AUTH_TEST_ISSUER=test-issuer
AUTH_TEST_AUDIENCE=test-audience

# Password hashing (lower values for faster tests)
AUTH_TEST_PASSWORD_ALGORITHM=argon2id
AUTH_TEST_BCRYPT_ROUNDS=10
AUTH_TEST_ARGON2_MEMORY_KB=4096
AUTH_TEST_ARGON2_TIME_COST=2
AUTH_TEST_ARGON2_PARALLELISM=1

# Throttling (faster for tests)
AUTH_TEST_THROTTLE_BASE_DELAY_MS=100
AUTH_TEST_THROTTLE_MAX_DELAY_MS=5000

# Email token TTLs (shorter for tests)
AUTH_TEST_PASSWORD_RESET_TTL_MINUTES=10
AUTH_TEST_INVITE_TTL_MINUTES=30
AUTH_TEST_VERIFY_EMAIL_TTL_MINUTES=10
