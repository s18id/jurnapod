# Database integration test configuration
# Copy to .env.test.db.local and customize for your environment

# Set to 1 to run tests against real database
AUTH_TEST_USE_DB=0

# Test database connection (safe defaults for local MySQL)
AUTH_TEST_DB_HOST=localhost
AUTH_TEST_DB_PORT=3306
AUTH_TEST_DB_USER=root
AUTH_TEST_DB_PASSWORD=
AUTH_TEST_DB_DATABASE=jurnapod_test
AUTH_TEST_DB_CONNECTION_LIMIT=5
