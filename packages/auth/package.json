{
  "name": "@jurnapod/auth",
  "version": "0.3.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./tokens": {
      "types": "./dist/tokens/index.d.ts",
      "default": "./dist/tokens/index.js"
    },
    "./passwords": {
      "types": "./dist/passwords/index.d.ts",
      "default": "./dist/passwords/index.js"
    },
    "./rbac": {
      "types": "./dist/rbac/index.d.ts",
      "default": "./dist/rbac/index.js"
    },
    "./oauth": {
      "types": "./dist/oauth/index.d.ts",
      "default": "./dist/oauth/index.js"
    },
    "./throttle": {
      "types": "./dist/throttle/index.d.ts",
      "default": "./dist/throttle/index.js"
    },
    "./email": {
      "types": "./dist/email/index.d.ts",
      "default": "./dist/email/index.js"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src --config eslint.config.mjs",
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "vitest run __test__/unit",
    "test:integration": "vitest run __test__/integration",
    "test:single": "vitest run"
  },
  "dependencies": {
    "@jurnapod/db": "0.3.0",
    "bcryptjs": "^3.0.2",
    "@node-rs/argon2": "^2.0.0",
    "jose": "^5.9.6",
    "kysely": "^0.28.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "dotenv": "^16.4.7",
    "tsx": "^4.19.0",
    "typescript": "^5.7.3",
    "vitest": "^3.0.0"
  }
}
