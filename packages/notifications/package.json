{
  "name": "@jurnapod/notifications",
  "version": "1.0.0",
  "description": "Email notification service for Jurnapod",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./templates/email": "./dist/templates/email.js",
    "./link-builder/email": "./dist/link-builder/email.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run __test__/unit",
    "test:integration": "vitest run __test__/integration",
    "test:single": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --config eslint.config.mjs"
  },
  "dependencies": {
    "@sendgrid/mail": "^8.1.0",
    "handlebars": "^4.7.8",
    "nodemailer": "^8.0.4"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/nodemailer": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  }
}
