{
  "name": "@jurnapod/modules-platform",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./audit": {
      "types": "./dist/audit/index.d.ts",
      "default": "./dist/audit/index.js"
    },
    "./audit/period-transition": {
      "types": "./dist/audit/period-transition.d.ts",
      "default": "./dist/audit/period-transition.js"
    },
    "./settings": {
      "types": "./dist/settings/index.d.ts",
      "default": "./dist/settings/index.js"
    },
    "./sync": {
      "types": "./dist/sync/index.d.ts",
      "default": "./dist/sync/index.js"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src --config eslint.config.mjs",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@jurnapod/db": "0.1.0",
    "@jurnapod/shared": "0.1.0"
  },
  "devDependencies": {
    "typescript": "^5.7.3",
    "vitest": "^1.6.1"
  }
}
