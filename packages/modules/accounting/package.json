{
  "name": "@jurnapod/modules-accounting",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./posting/cogs": {
      "types": "./dist/posting/cogs.d.ts",
      "default": "./dist/posting/cogs.js"
    },
    "./reconciliation": {
      "types": "./dist/reconciliation/index.d.ts",
      "default": "./dist/reconciliation/index.js"
    },
    "./reconciliation/subledger": {
      "types": "./dist/reconciliation/subledger/index.d.ts",
      "default": "./dist/reconciliation/subledger/index.js"
    },
    "./trial-balance": {
      "types": "./dist/trial-balance/index.d.ts",
      "default": "./dist/trial-balance/index.js"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --import ../../../scripts/test/load-root-env.mjs --test --import tsx src/posting.test.ts",
    "lint": "eslint src --config eslint.config.mjs"
  },
  "dependencies": {
    "@jurnapod/db": "0.1.0",
    "@jurnapod/shared": "0.1.0"
  },
  "devDependencies": {
    "typescript": "^5.7.3"
  }
}
