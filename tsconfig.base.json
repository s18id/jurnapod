{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@jurnapod/db": ["packages/db/src/index.ts"],
      "@jurnapod/shared": ["packages/shared/src/index.ts"],
      "@jurnapod/core": ["packages/core/src/index.ts"],
      "@jurnapod/sync-core": ["packages/sync-core/src/index.ts"],
      "@jurnapod/pos-sync": ["packages/pos-sync/src/index.ts"],
      "@jurnapod/backoffice-sync": ["packages/backoffice-sync/src/index.ts"],
      "@jurnapod/modules-platform": ["packages/modules/platform/src/index.ts"],
      "@jurnapod/modules-platform/sync": ["packages/modules/platform/src/sync/index.ts"],
      "@/lib/*": ["apps/api/src/lib/*"],
      "@/lib": ["apps/api/src/lib"],
      "@/services/*": ["apps/api/src/services/*"],
      "@/services": ["apps/api/src/services"]
    },
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true
  }
}
