# Development Server Ports & Binding
# API Server
# PORT or API_PORT: Port for the API server (default: 3001)
# HOST: Bind address for the API server (default: 0.0.0.0 for all interfaces)
#       Use 127.0.0.1 to restrict to localhost only
# PORT=3001
# HOST=0.0.0.0

# Frontend Dev Servers (Vite)
# BACKOFFICE_PORT: Port for backoffice dev server (default: 3002)
# POS_PORT: Port for POS dev server (default: 5173)
# BACKOFFICE_PORT=3002
# POS_PORT=5173

# Database Configuration
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=jurnapod
DB_COLLATION=utf8mb4_uca1400_ai_ci

DB_MIGRATE_LOCK_TIMEOUT=60

JP_COMPANY_CODE=JP
JP_COMPANY_NAME=Jurnapod Demo
JP_OUTLET_CODE=MAIN
JP_OUTLET_NAME=Main Outlet
JP_OWNER_EMAIL=owner@example.com
JP_OWNER_PASSWORD=ChangeMe123!
# SUPER_ADMIN user for platform management (optional)
JP_SUPER_ADMIN_EMAIL=superadmin@example.com
JP_SUPER_ADMIN_PASSWORD=SuperAdmin123!

AUTH_JWT_ACCESS_SECRET=replace-with-long-random-secret
AUTH_JWT_ACCESS_TTL_SECONDS=3600
AUTH_REFRESH_SECRET=replace-with-long-random-secret
AUTH_REFRESH_TTL_SECONDS=2592000
AUTH_JWT_ISSUER=jurnapod-api
AUTH_JWT_AUDIENCE=jurnapod-clients
AUTH_PASSWORD_ALGO_DEFAULT=argon2id
AUTH_PASSWORD_REHASH_ON_LOGIN=true
AUTH_BCRYPT_ROUNDS=12
AUTH_ARGON2_MEMORY_KB=65536
AUTH_ARGON2_TIME_COST=3
AUTH_ARGON2_PARALLELISM=1
AUTH_LOGIN_THROTTLE_BASE_MS=10000
AUTH_LOGIN_THROTTLE_MAX_MS=300000

# Enable cross-origin refresh cookies when API and frontends are on different origins
AUTH_REFRESH_COOKIE_CROSS_SITE=false

# Google SSO (optional)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URIS=

# CORS Configuration (Production only)
# Comma-separated list of allowed origins for cross-origin requests
# Example: https://backoffice.example.com,https://pos.example.com
# Leave empty or comment out for development (uses localhost origins)
CORS_ALLOWED_ORIGINS=

# Frontend base URLs (optional)
# Backoffice/POS API base URL (e.g. https://api.example.com/api)
VITE_API_BASE_URL=
# Frontend Google OAuth client ID
VITE_GOOGLE_OAUTH_CLIENT_ID=
# Backoffice: dev proxy target for /api (defaults to http://localhost:3001)
VITE_API_PROXY_TARGET=
# Backoffice: POS domain for the "Open POS" link (e.g. https://pos.example.com)
VITE_POS_BASE_URL=

# POS build metadata (auto-generated by build process)
# These are automatically set by the build script from package.json version and git SHA
# No need to set manually - included here for documentation only
# VITE_APP_VERSION=0.2.2
# VITE_BUILD_NUMBER=b44def9

# Mailer Configuration
# Driver: smtp | log | disabled (default: disabled)
MAILER_DRIVER=disabled
# From address defaults
MAILER_FROM_NAME=Jurnapod
MAILER_FROM_EMAIL=noreply@example.com
# SMTP settings (required when MAILER_DRIVER=smtp)
MAILER_SMTP_HOST=mail.example.com
MAILER_SMTP_PORT=587
MAILER_SMTP_USER=noreply@example.com
MAILER_SMTP_PASS=
MAILER_SMTP_SECURE=false
MAILER_SMTP_TLS_REJECT_UNAUTHORIZED=true

# Platform Settings Encryption
# Required for encrypting sensitive platform settings (e.g., SMTP passwords)
# Generate with: openssl rand -hex 32
PLATFORM_SETTINGS_ENCRYPTION_KEY=

# Email Token TTLs (in minutes)
EMAIL_TOKEN_TTL_RESET_MIN=60
EMAIL_TOKEN_TTL_INVITE_MIN=10080
EMAIL_TOKEN_TTL_VERIFY_MIN=1440

# Email Outbox Retry Configuration
EMAIL_OUTBOX_RETRY_MAX=5
EMAIL_OUTBOX_RETRY_BACKOFF=60

# App Configuration
# Public URL for generating email links (required in production)
APP_PUBLIC_URL=http://localhost:3001

# Cron Configuration
# Secret for protecting cron endpoints (generate with: openssl rand -hex 32)
CRON_EMAIL_OUTBOX_SECRET=replace-with-long-random-secret

# Development HTTP Logging
# Set to 1 to log all API requests in development (shows in npm run dev terminal)
JP_HTTP_LOG=1
# Include /api/health in logs (default: excluded)
JP_HTTP_LOG_HEALTH=1
