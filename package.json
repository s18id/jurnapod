{
  "name": "jurnapod",
  "private": true,
  "version": "0.2.2",
  "engines": {
    "node": "20.x"
  },
  "workspaces": [
    "apps/*",
    "packages/*",
    "packages/modules/*"
  ],
  "scripts": {
    "clean": "npx rimraf dist \"apps/*/dist\" \"packages/*/dist\" \"packages/modules/*/dist\" \"**/*.tsbuildinfo\"",
    "prebuild": "npm run build -w @jurnapod/offline-db",
    "build": "npm run build -ws --if-present",
    "build:clean": "npm run clean && npm run build",
    "dev": "npm run dev:check && concurrently -n api,backoffice,pos,offline-db -c blue,green,magenta,yellow --restart-tries 1 --restart-after 5000 \"npm:dev:api\" \"npm run dev:backoffice:wait\" \"npm run dev:pos:wait\" \"npm:dev:offline-db:watch\"",
    "dev:all": "npm run dev",
    "dev:api+backoffice": "npm run dev:check && concurrently -n api,backoffice -c blue,green --restart-tries 1 --restart-after 5000 \"npm:dev:api\" \"npm run dev:backoffice:wait\"",
    "dev:api+pos": "npm run dev:check && concurrently -n api,pos -c blue,magenta --restart-tries 1 --restart-after 5000 \"npm:dev:api\" \"npm run dev:pos:wait\"",
    "dev:backoffice:wait": "node scripts/wait-for-api.mjs && npm run dev:backoffice",
    "dev:pos:wait": "node scripts/wait-for-api.mjs && npm run dev:pos",
    "dev:offline-db:watch": "npm run build:watch -w @jurnapod/offline-db",
    "dev:check": "node scripts/check-env.mjs",
    "dev:kill": "node scripts/kill-ports.mjs",
    "dev:stop": "npm run dev:kill",
    "dev:restart": "npm run dev:stop && npm run dev",
    "typecheck": "npm run typecheck -ws --if-present",
    "lint": "npm run lint -ws --if-present",
    "lint:docs:responses": "node scripts/lint-docs-responses.mjs",
    "dev:pos": "npm run dev -w @jurnapod/pos -- --host=0.0.0.0",
    "dev:api": "npm run dev -w @jurnapod/api",
    "dev:backoffice": "npm run dev -w @jurnapod/backoffice -- --host=0.0.0.0",
    "pos:build-meta": "node ./scripts/gen-pos-build-meta.mjs --format=shell",
    "build:pos": "npm run build -w @jurnapod/pos",
    "build:api": "npm run build -w @jurnapod/api",
    "build:backoffice": "npm run build -w @jurnapod/backoffice",
    "qa:pos:e2e": "npm run qa:e2e -w @jurnapod/pos",
    "qa:pos:e2e:real": "npm run qa:e2e:real -w @jurnapod/pos",
    "qa:pos:lhci": "npm run qa:lhci -w @jurnapod/pos",
    "qa:pos:full": "npm run qa:pos:e2e && npm run qa:pos:lhci",
    "db:migrate": "npm run db:migrate -w @jurnapod/db",
    "db:script": "npm run db:script -w @jurnapod/db --",
    "db:seed": "npm run db:seed -w @jurnapod/db",
    "db:seed:test-accounts": "npm run db:seed:test-accounts -w @jurnapod/db",
    "db:smoke": "npm run db:smoke -w @jurnapod/db",
    "db:backfill:pos-journals": "npm run db:backfill:pos-journals -w @jurnapod/db --",
    "db:reconcile:pos-journals": "npm run db:reconcile:pos-journals -w @jurnapod/db --",
    "db:audit:system-roles": "npm run db:audit:system-roles -w @jurnapod/db",
    "db:consolidate:system-roles": "npm run db:consolidate:system-roles -w @jurnapod/db",
    "test:scripts": "node --test scripts/tests/*.test.mjs",
    "auth:secret:generate": "node ./scripts/auth-secret-generate.mjs",
    "auth:secret:regenerate": "node ./scripts/auth-secret-regenerate.mjs",
    "auth:refresh-secret:generate": "node ./scripts/auth-refresh-secret-generate.mjs",
    "auth:refresh-secret:regenerate": "node ./scripts/auth-refresh-secret-regenerate.mjs",
    "platform:encryption-key:generate": "node ./scripts/platform-encryption-key-generate.mjs",
    "platform:encryption-key:regenerate": "node ./scripts/platform-encryption-key-regenerate.mjs",
    "cron:email-secret:generate": "node ./scripts/cron-email-secret-generate.mjs",
    "cron:email-secret:regenerate": "node ./scripts/cron-email-secret-regenerate.mjs",
    "deploy:pos": "node scripts/deploy.mjs --app=pos",
    "deploy:backoffice": "node scripts/deploy.mjs --app=backoffice"
  },
  "devDependencies": {
    "@types/bwip-js": "^3.2.3",
    "concurrently": "^9.2.1",
    "nodemon": "^3.1.14",
    "rimraf": "^5.0.10",
    "wait-on": "^8.0.1"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.11",
    "@tabler/icons-react": "^3.40.0",
    "hono": "^4.12.8"
  }
}
