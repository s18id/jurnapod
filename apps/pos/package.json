{
  "name": "@jurnapod/pos",
  "version": "0.3.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "npm run build -w @jurnapod/offline-db",
    "dev": "vite",
    "prebuild": "npm run build -w @jurnapod/offline-db",
    "build:meta": "node ../../scripts/gen-pos-build-meta.mjs --format=shell",
    "build": "eval \"$(npm run -s build:meta)\" && vite build",
    "preview": "vite preview",
    "qa:pwa:build": "npm run build",
    "qa:pwa:preview": "npm run preview -- --host 127.0.0.1 --port 4173 --strictPort",
    "qa:e2e": "playwright test",
    "qa:e2e:headed": "playwright test --headed",
    "qa:e2e:install": "playwright install chromium",
    "qa:e2e:real": "playwright test --config=playwright.real.config.ts",
    "qa:lhci": "CHROME_PATH=$(node -e \"const { chromium } = require('playwright'); process.stdout.write(chromium.executablePath());\") node ./scripts/qa-lighthouse.mjs",
    "build:offline": "tsc -p tsconfig.json",
    "pretypecheck": "npm run build -w @jurnapod/offline-db",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint . --max-warnings=0",
    "pretest": "npm run build -w @jurnapod/offline-db",
    "test": "node --import ../../scripts/test/load-root-env.mjs --import tsx --test src/offline/__tests__/*.test.mjs"
  },
  "dependencies": {
    "@capacitor/android": "8.0.1",
    "@capacitor/app": "8.0.1",
    "@capacitor/device": "8.0.1",
    "@capacitor/ios": "8.0.1",
    "@capacitor/network": "8.0.1",
    "@ionic/react": "^8.8.1",
    "@jurnapod/offline-db": "file:../../packages/offline-db",
    "dexie": "^4.0.11",
    "ionicons": "^8.0.13",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.13.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@capacitor/cli": "8.0.1",
    "@capacitor/core": "8.0.1",
    "@eslint/eslintrc": "^3.3.1",
    "@playwright/test": "^1.55.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.4.1",
    "eslint": "^9.23.0",
    "fake-indexeddb": "^6.2.5",
    "lighthouse": "^12.1.0",
    "tsx": "^4.20.3",
    "typescript": "^5.7.3",
    "vite": "^5.4.15"
  }
}
