{
  "name": "@jurnapod/backoffice",
  "version": "0.3.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "npm run build -w @jurnapod/offline-db",
    "dev": "vite",
    "prebuild": "npm run build -w @jurnapod/shared",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint . --max-warnings=0",
    "test": "node --import ../../scripts/test/load-root-env.mjs --test --import tsx src/tests/all.test.ts",
    "qa:e2e": "playwright test",
    "qa:e2e:headed": "playwright test --headed",
    "qa:e2e:install": "playwright install chromium",
    "qa:e2e:axe": "playwright test --grep \"accessibility\"",
    "qa:e2e:ui": "playwright test --ui",
    "qa:e2e:debug": "playwright test --debug",
    "qa:e2e:single": "playwright test",
    "qa:ct": "playwright test -c playwright.ct.config.ts",
    "qa:ct:headed": "playwright test -c playwright.ct.config.ts --headed"
  },
  "dependencies": {
    "@fontsource/ibm-plex-sans": "^5.2.6",
    "@fontsource/newsreader": "^5.2.6",
    "@mantine/core": "^7.17.1",
    "@mantine/dates": "^7.17.1",
    "@mantine/hooks": "^7.17.1",
    "@mantine/notifications": "^7.17.1",
    "@tanstack/react-table": "^8.21.3",
    "dexie": "^4.0.4",
    "dompurify": "^3.2.4",
    "marked": "^12.0.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "reconnecting-websocket": "^4.4.0"
  },
  "devDependencies": {
    "@types/dompurify": "^3.2.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "@vitejs/plugin-react": "^4.7.0",
    "@playwright/test": "^1.55.0",
    "@playwright/experimental-ct-react": "^1.55.0",
    "@axe-core/playwright": "^4.10.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.3",
    "vite": "^5.4.21",
    "vite-plugin-pwa": "^0.20.5"
  }
}
