{
  "name": "@jurnapod/api",
  "version": "0.3.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nodemon --watch src --watch app --ext ts --exec 'node --import tsx src/server.ts'",
    "test-server": "NODE_ENV=test node --import ../../scripts/test/load-root-env.mjs --import tsx --watch src/server.ts",
    "build": "tsc --noEmit",
    "start": "NODE_ENV=production node --import tsx src/server.ts",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run __test__/unit",
    "test:integration": "vitest run __test__/integration",
    "test:split:list": "node --import ../../scripts/test/load-root-env.mjs ./scripts/run-vitest-split.mjs list --scope=integration --write-lists",
    "test:integration:fast": "vitest run __test__/integration --testNamePattern='^(?!.*@slow).*$'",
    "test:integration:slow": "vitest run __test__/integration --testNamePattern='@slow'",
    "test:integration:fast:log": "sh -c 'npm run test:integration:fast > /tmp/api-fast.log 2>&1; code=$?; echo \"LOG=/tmp/api-fast.log EXIT=$code\"; exit $code'",
    "test:integration:slow:log": "sh -c 'npm run test:integration:slow > /tmp/api-slow.log 2>&1; code=$?; echo \"LOG=/tmp/api-slow.log EXIT=$code\"; exit $code'",
    "test:batch": "node --import ../../scripts/test/load-root-env.mjs ./scripts/run-vitest-batch.mjs",
    "test:single": "vitest run",
    "test:watch": "vitest",
    "test:ws": "node ../../scripts/websocket-test.js",
    "fix:duplicate-roles": "tsx src/scripts/fix-duplicate-role-assignments.ts",
    "check:test-sql": "npx tsx scripts/check-test-sql.ts",
    "generate:openapi-scaffold": "tsx scripts/generate-openapi-scaffold.ts"
  },
  "dependencies": {
    "@hono/zod-openapi": "^0.14.8",
    "@js-temporal/polyfill": "^0.5.1",
    "@jurnapod/auth": "0.3.0",
    "@jurnapod/backoffice-sync": "0.3.0",
    "@jurnapod/db": "0.3.0",
    "@jurnapod/modules-accounting": "0.3.0",
    "@jurnapod/modules-inventory": "0.3.0",
    "@jurnapod/modules-platform": "0.3.0",
    "@jurnapod/modules-reporting": "0.3.0",
    "@jurnapod/modules-sales": "0.3.0",
    "@jurnapod/pos-sync": "0.3.0",
    "@jurnapod/shared": "0.3.0",
    "@jurnapod/sync-core": "0.3.0",
    "@node-rs/argon2": "^2.0.2",
    "@scalar/hono-api-reference": "^0.10.6",
    "bcryptjs": "^3.0.2",
    "bwip-js": "^4.8.0",
    "hono": "^4.0.0",
    "jose": "^6.1.2",
    "marked": "^12.0.2",
    "mysql2": "^3.15.3",
    "nodemailer": "^6.9.15",
    "papaparse": "^5.5.3",
    "prom-client": "^15.1.3",
    "puppeteer-core": "^22.15.0",
    "sanitize-html": "^2.14.0",
    "sharp": "^0.33.5",
    "ws": "^8.19.0",
    "xlsx": "^0.18.5",
    "xlsx-stream-reader": "^1.1.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.3",
    "@types/node": "25.3.0",
    "@types/nodemailer": "^6.4.16",
    "@types/papaparse": "^5.5.2",
    "@types/proper-lockfile": "^4.1.4",
    "@types/sanitize-html": "^2.13.0",
    "@types/ws": "^8.18.1",
    "eslint": "^9.39.3",
    "tsx": "^4.20.3",
    "typescript": "^5.7.3",
    "vitest": "^3.0.0"
  }
}
