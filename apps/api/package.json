{
  "name": "@jurnapod/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nodemon --watch src --watch app --ext ts --exec 'node --import tsx src/server.ts'",
    "build": "tsc --noEmit",
    "start": "NODE_ENV=production node --import tsx src/server.ts",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "npm run test:unit",
    "test:unit": "node --test --test-concurrency=1 --import tsx src/**/*.test.ts",
    "test:unit:auth": "node --test --test-concurrency=1 --import tsx src/lib/auth.test.ts",
    "test:unit:supplies": "node --test --test-concurrency=1 --import tsx src/lib/master-data.supplies.test.ts",
    "test:integration": "node --test --test-concurrency=1 tests/integration/*.integration.test.mjs",
    "test:integration:verbose": "JP_INTEGRATION_VERBOSE=1 JP_HTTP_LOG=1 node --test --test-concurrency=1 tests/integration/*.integration.test.mjs",
    "test:all": "npm run test:unit && npm run test:integration",
    "test:ws": "node ../../scripts/websocket-test.js",
    "test:phase3": "node --test --test-concurrency=1 --import tsx src/lib/phase3-batch.test.ts"
  },
  "dependencies": {
    "@jurnapod/backoffice-sync": "0.1.0",
    "@jurnapod/modules-accounting": "0.1.0",
    "@jurnapod/modules-platform": "0.1.0",
    "@jurnapod/pos-sync": "0.1.0",
    "@jurnapod/shared": "0.1.0",
    "@jurnapod/sync-core": "0.1.0",
    "@node-rs/argon2": "^2.0.2",
    "bcryptjs": "^3.0.2",
    "bwip-js": "^4.8.0",
    "hono": "^4.0.0",
    "jose": "^6.1.2",
    "marked": "^12.0.2",
    "mysql2": "^3.15.3",
    "nodemailer": "^6.9.15",
    "puppeteer-core": "^22.15.0",
    "sanitize-html": "^2.14.0",
    "sharp": "^0.33.5",
    "ws": "^8.19.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.3",
    "@types/node": "25.3.0",
    "@types/nodemailer": "^6.4.16",
    "@types/sanitize-html": "^2.13.0",
    "@types/ws": "^8.18.1",
    "eslint": "^9.39.3",
    "tsx": "^4.20.3",
    "typescript": "^5.7.3"
  }
}
