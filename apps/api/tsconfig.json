{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "noEmit": true,
    "incremental": true,
    "isolatedModules": true,
    "jsx": "preserve"
  },
  "include": [
    "instrumentation.ts",
    "app/**/*.ts",
    "app/**/*.tsx",
    "src",
    "__test__"
  ],
  "exclude": [
    "node_modules"
  ]
}
